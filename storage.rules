rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Users can only read/write images in their own project folders
    match /users/{userId}/projects/{projectId}/image {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
