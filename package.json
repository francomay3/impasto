{
  "name": "impasto",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit && eslint . --max-warnings=0 && knip && bun scripts/check-file-length.ts && vitest run --coverage",
    "knip": "knip",
    "preview": "vite preview",
    "build:wasm": "npm run build:wasm:img_ops && npm run build:wasm:img_index",
    "build:wasm:img_ops": "wasm-pack build crates/img_ops --target web --out-dir ../../src/wasm/img_ops",
    "build:wasm:img_index": "wasm-pack build crates/img_index --target web --out-dir ../../src/wasm/img_index",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:update-snapshots": "playwright test --update-snapshots",
    "test:report": "playwright show-report",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@mantine/notifications": "^8.3.18",
    "@react-pdf/renderer": "^4.3.2",
    "@tanstack/react-query": "^5.95.2",
    "chroma-js": "^3.2.0",
    "firebase": "^12.11.0",
    "lucide-react": "^0.577.0",
    "ml-kmeans": "^7.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "knip": "^6.0.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "wasm-pack": "^0.14.0"
  }
}
